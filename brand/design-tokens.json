      "mid":   { "value": "#24487A", "type": "color", "description": "Mid-navy — cards, overlays" }
    },
    "gold": {
      "base":  { "value": "#C8973A", "type": "color", "description": "Primary accent gold" },
      "light": { "value": "#E8C46A", "type": "color", "description": "Light gold — hover, secondary accents" }
    },
    "neutral": {
      "cream":      { "value": "#F4F1EB", "type": "color", "description": "Primary page background" },
      "warm-gray":  { "value": "#E2DDD4", "type": "color", "description": "Dividers, subtle borders" },
      "light-gray": { "value": "#E8E4DC", "type": "color", "description": "Card backgrounds on cream" },
      "white":      { "value": "#FFFFFF", "type": "color", "description": "Pure white surfaces" },
      "near-black": { "value": "#1A1A2E", "type": "color", "description": "Body text on light backgrounds" },
      "mid-gray":   { "value": "#64748B", "type": "color", "description": "Secondary text, captions" },
      "blue-gray":  { "value": "#8BA8C8", "type": "color", "description": "Muted text on dark backgrounds" },
